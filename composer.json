{
  "name": "sharegate/nextcloud-app",
  "description": "ShareGate paid file sharing for Nextcloud",
  "type": "project",
  "license": "AGPL-3.0-or-later",
  "require": {
    "php": ">=8.1",
    "alipaysdk/easysdk": "^2.2",
    "chillerlan/php-qrcode": "^5.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5"
  },
  "autoload": {
    "psr-4": {
      "OCA\\ShareGate\\": "lib/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "OCA\\ShareGate\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit --configuration phpunit.xml.dist"
  },
  "config": {
    "optimize-autoloader": true,
    "sort-packages": true
  }
}
